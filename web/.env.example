# ---- Supabase ----
# Project URL and anon key are safe to expose to the browser (used with RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key is SERVER-ONLY. Never expose to the client. Used by ingestion
# scripts and privileged server routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
# Drafting + embedding models (override if needed).
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Auth (Phase 2) ----
# The ONLY Google account allowed to use the app (owner-only access).
# Must match the Google account you sign in with.
OWNER_EMAIL=you@gmail.com

# ---- Ingestion ----
# Path to the course knowledge-base CSV, relative to the web/ directory.
COURSES_CSV_PATH=../vizura_courses_150.csv
